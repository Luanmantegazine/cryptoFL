# ============================================================================
# CryptoFL — example environment file
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored and MUST NOT be committed. Every variable below is
# read somewhere in the codebase (Python `os.getenv(...)` or Hardhat
# `configVariable(...)`). The baseline / no_ipfs / ablation / security
# experiments run WITHOUT most of these (no blockchain, no IPFS); they are
# only needed for the `full` on-chain flow and Arbitrum deployment.
# ============================================================================

# ---------------------------------------------------------------------------
# Blockchain — RPC + signer (used by flower_fl/onchain_*.py and hardhat.config.ts)
# ---------------------------------------------------------------------------
# JSON-RPC endpoint. For a local Hardhat node use http://127.0.0.1:8545 .
# For Arbitrum Sepolia use https://sepolia-rollup.arbitrum.io/rpc .
RPC_URL=http://127.0.0.1:8545
# Private key of the signer. The value below is Hardhat account #0 — a WELL-KNOWN
# PUBLIC test key. NEVER put a real funded mainnet/testnet key in a committed file.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Optional: explicit chain id (otherwise read from the node).
CHAIN_ID=31337

# ---------------------------------------------------------------------------
# Contract ABIs + addresses (produced by `npx hardhat compile` / deploy scripts)
# ---------------------------------------------------------------------------
DAO_ABI_PATH=artifacts/contracts/DAO.sol/DAO.json
JOB_ABI_PATH=artifacts/contracts/JobContract.sol/JobContract.json
# DAO address. If empty, it is auto-discovered from deployments/ or
# ignition/deployments/ (see flower_fl/deployments.py).
DAO_ADDRESS=
# JobContract address(es). `deploy_job.py` writes both after creating a job.
# JOB_ADDRS is read by the server (comma-separated); JOB_ADDR by each client.
JOB_ADDRS=
JOB_ADDR=
# Where deployment JSONs are searched for address auto-discovery.
DEPLOYMENTS_DIR=deployments
IGNITION_DIR=ignition/deployments

# ---------------------------------------------------------------------------
# IPFS storage (used by flower_fl/ipfs.py) — only for the `full` flow
# ---------------------------------------------------------------------------
# Pinata JWT for pinning model weights. Get one at https://pinata.cloud .
# ⚠ A real Pinata JWT was previously committed in this repo's history and MUST
#   be rotated (revoked + regenerated). Do not reuse it.
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Alternative to Pinata: a local IPFS daemon (e.g. http://127.0.0.1:5001).
IPFS_API_URL=
# Optional comma-separated read gateways for downloads (fallbacks).
IPFS_GATEWAYS=

# ---------------------------------------------------------------------------
# Experiment configuration (read by server/client/runners)
# ---------------------------------------------------------------------------
# Number of FL rounds and minimum clients per round.
ROUNDS=3
MIN_CLIENTS=3
# Persist metrics JSON? and where to.
SAVE_METRICS=true
METRICS_FILE=results/server_metrics.json
# Baseline runner (Flower-only, no blockchain) overrides:
BASELINE_METRICS_FILE=results/baseline_metrics.json
BASELINE_SERVER_ADDRESS=0.0.0.0:8081

# ---------------------------------------------------------------------------
# Model / dataset selection (read by client.py / server.py)
# ---------------------------------------------------------------------------
# MODEL: mnistnet | resnet18    DATASET: mnist | cifar10
MODEL=mnistnet
DATASET=mnist
# Dirichlet alpha for non-IID CIFAR-10 partitioning (small = more non-IID).
DIRICHLET_ALPHA=0.5
# RNG seed for reproducible partitioning across repetitions.
SEED=42

# ---------------------------------------------------------------------------
# Anomaly detection (server.py) — flags norm-inflating updates
# ---------------------------------------------------------------------------
# Flag updates whose L2 norm > mean + N*std across a round. Targets norm-
# inflating attacks (noise/zero); orthogonal to label-flipping.
DETECT_ANOMALIES=true
NORM_THRESHOLD_STD=2.0
# When true, skip IPFS + on-chain publishing (the `no_ipfs` ablation mode).
SKIP_IPFS=false

# ---------------------------------------------------------------------------
# Malicious-client simulation (client.py) — set per-client by experiments
# ---------------------------------------------------------------------------
# MALICIOUS=true enables local poisoning. ATTACK_TYPE: label_flip | noise | zero.
MALICIOUS=false
ATTACK_TYPE=label_flip
ATTACK_PROB=1.0

# ---------------------------------------------------------------------------
# Hardhat extra networks (hardhat.config.ts, optional — only if you use them)
# ---------------------------------------------------------------------------
# Each <NET>_RPC_URL / <NET>_PRIVATE_KEY pair powers a named network.
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
OPTIMISM_RPC_URL=
OPTIMISM_PRIVATE_KEY=
ARBITRUM_RPC_URL=
ARBITRUM_PRIVATE_KEY=
BASE_RPC_URL=
BASE_PRIVATE_KEY=
# Used only by scripts/load_test_matching.ts (defaults to http://127.0.0.1:8545).
LOCAL_RPC_URL=http://127.0.0.1:8545
